{
  "name": "cv-builder-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 4C backend billing, entitlements, and freemium gating for CV Builder",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect:import": "tsx scripts/inspect-import-parser.ts",
    "stripe:webhook-secret": "stripe listen --forward-to localhost:4000/api/v1/billing/webhooks --print-secret",
    "stripe:listen": "stripe listen --forward-to localhost:4000/api/v1/billing/webhooks"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@napi-rs/canvas": "^0.1.99",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "pino": "^9.9.5",
    "pino-http": "^10.5.0",
    "stripe": "^16.12.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^20.17.51",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
