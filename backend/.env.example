APP_NAME=cv-builder-backend
APP_ENV=development
APP_VERSION=0.1.0
PORT=4000
LOG_LEVEL=info
FRONTEND_APP_URL=http://localhost:5173

AI_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-3-flash-preview
AI_PROMPT_PROFILE=phase3-v1
GEMINI_API_KEY=
AI_GEMINI_MAX_ATTEMPTS=4
AI_GEMINI_RETRY_BASE_DELAY_MS=1000
AI_GEMINI_RETRY_MAX_DELAY_MS=16000
EXPORTS_STORAGE_BUCKET=exports
EXPORT_DOWNLOAD_URL_TTL_SECONDS=600

PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGES=eng
PDF_OCR_MAX_PAGES=2
PDF_OCR_RENDER_SCALE=2
PDF_OCR_CACHE_PATH=/tmp/cv-builder-ocr-cache

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
BILLING_CHECKOUT_SUCCESS_URL=http://localhost:5173/app/pricing?checkout=success
BILLING_CHECKOUT_CANCEL_URL=http://localhost:5173/app/pricing?checkout=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:5173/app/pricing
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
